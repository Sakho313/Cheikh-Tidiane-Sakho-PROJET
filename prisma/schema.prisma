// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  COMPLIANCE_OFFICER
  AUDITOR
  VIEWER
}

enum Sector {
  ENERGY
  TRANSPORT
  BANKING
  FINANCIAL_MARKETS
  HEALTH
  DRINKING_WATER
  WASTEWATER
  DIGITAL_INFRASTRUCTURE
  ICT_SERVICE
  PUBLIC_ADMIN
  SPACE
  POSTAL
  WASTE_MANAGEMENT
  CHEMICAL
  FOOD
  MANUFACTURING
  DIGITAL_PROVIDERS
  RESEARCH
}

enum EntityType {
  ESSENTIAL
  IMPORTANT
}

enum ComplianceStatus {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
  NOT_APPLICABLE
  PENDING
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  DRAFT
  DETECTED
  REPORTED_INITIAL
  INVESTIGATING
  REPORTED_FINAL
  RESOLVED
  CLOSED
}

enum RiskCategory {
  NETWORK
  SUPPLY_CHAIN
  HUMAN
  PHYSICAL
  SOFTWARE
  HARDWARE
  DATA
  LEGAL
  OPERATIONAL
}

enum RiskStatus {
  IDENTIFIED
  ASSESSED
  MITIGATING
  MITIGATED
  ACCEPTED
  CLOSED
}

enum AuditType {
  INTERNAL
  EXTERNAL
  REGULATORY
  SUPPLIER
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FindingSeverity {
  OBSERVATION
  MINOR
  MAJOR
  CRITICAL
}

enum FindingStatus {
  OPEN
  IN_REMEDIATION
  REMEDIATED
  ACCEPTED
  CLOSED
}

enum ReportType {
  COMPLIANCE
  INCIDENT
  RISK
  AUDIT
  EXECUTIVE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Organization {
  id           String     @id @default(uuid())
  name         String
  sector       Sector
  entityType   EntityType
  country      String
  contactEmail String
  contactPhone String?
  address      String?
  website      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  users                 User[]
  complianceAssessments ComplianceAssessment[]
  incidents             Incident[]
  risks                 Risk[]
  audits                Audit[]
  reports               Report[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role      @default(VIEWER)
  organizationId String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization          Organization?          @relation(fields: [organizationId], references: [id])
  assignedAssessments   ComplianceAssessment[] @relation("AssignedAssessments")
  createdIncidents      Incident[]             @relation("CreatedIncidents")
  ownedRisks            Risk[]                 @relation("OwnedRisks")
  assignedAudits        Audit[]                @relation("AuditAuditor")
  generatedReports      Report[]               @relation("GeneratedReports")

  @@map("users")
}

model ComplianceControl {
  id          String  @id @default(uuid())
  article     String
  domain      String
  requirement String
  description String  @db.Text
  isActive    Boolean @default(true)

  assessments    ComplianceAssessment[]
  auditFindings  AuditFinding[]

  @@map("compliance_controls")
}

model ComplianceAssessment {
  id             String           @id @default(uuid())
  organizationId String
  controlId      String
  status         ComplianceStatus @default(PENDING)
  evidence       String?          @db.Text
  notes          String?          @db.Text
  assignedToId   String?
  dueDate        DateTime?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  control      ComplianceControl @relation(fields: [controlId], references: [id])
  assignedTo   User?             @relation("AssignedAssessments", fields: [assignedToId], references: [id])

  @@unique([organizationId, controlId])
  @@map("compliance_assessments")
}

model Incident {
  id                   String           @id @default(uuid())
  organizationId       String
  title                String
  description          String           @db.Text
  severity             IncidentSeverity
  status               IncidentStatus   @default(DRAFT)
  incidentType         String
  detectedAt           DateTime
  reportedAt           DateTime?
  resolvedAt           DateTime?
  affectedSystems      String[]
  impactDescription    String?          @db.Text
  reportedToAuthority  Boolean          @default(false)
  authorityReference   String?
  estimatedUsers       Int?
  createdById          String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CreatedIncidents", fields: [createdById], references: [id])

  @@map("incidents")
}

model Risk {
  id              String       @id @default(uuid())
  organizationId  String
  title           String
  description     String       @db.Text
  category        RiskCategory
  likelihood      Int
  impact          Int
  riskScore       Int
  status          RiskStatus   @default(IDENTIFIED)
  mitigationPlan  String?      @db.Text
  ownerId         String?
  reviewDate      DateTime?
  closedAt        DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User?        @relation("OwnedRisks", fields: [ownerId], references: [id])

  @@map("risks")
}

model Audit {
  id             String      @id @default(uuid())
  organizationId String
  title          String
  type           AuditType
  status         AuditStatus @default(PLANNED)
  startDate      DateTime
  endDate        DateTime?
  auditorId      String?
  scope          String?     @db.Text
  methodology    String?     @db.Text
  summary        String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditor      User?         @relation("AuditAuditor", fields: [auditorId], references: [id])
  findings     AuditFinding[]

  @@map("audits")
}

model AuditFinding {
  id             String          @id @default(uuid())
  auditId        String
  title          String
  description    String          @db.Text
  severity       FindingSeverity
  status         FindingStatus   @default(OPEN)
  controlId      String?
  recommendation String?         @db.Text
  dueDate        DateTime?
  closedAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  audit   Audit              @relation(fields: [auditId], references: [id], onDelete: Cascade)
  control ComplianceControl? @relation(fields: [controlId], references: [id])

  @@map("audit_findings")
}

model Report {
  id             String     @id @default(uuid())
  organizationId String
  type           ReportType
  title          String
  periodStart    DateTime?
  periodEnd      DateTime?
  generatedById  String
  data           Json
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedBy  User         @relation("GeneratedReports", fields: [generatedById], references: [id])

  @@map("reports")
}
