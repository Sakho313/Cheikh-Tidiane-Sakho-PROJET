# ── Frontend environment (Vite) ──────────────────────────────────────────────
# Copy to `.env` for local dev. On Render these are set on the static site.
# Vite only exposes variables prefixed with VITE_ and inlines them at BUILD time.

# Base URL of the API. Leave empty to use the relative `/api/v1` path, which the
# Render rewrite proxies to the backend (same-origin → no CORS). Set it only if
# you call the backend cross-origin.
# VITE_API_BASE_URL=

# ── Shared demo account (read-only) ───────────────────────────────────────────
# Powers the demo access on the login page. Must match the backend seed
# (DEMO_EMAIL / DEMO_PASSWORD). These defaults work out of the box; change them
# only if you also change them on the API service.
VITE_DEMO_EMAIL=demo@sao-nis2.com
VITE_DEMO_PASSWORD=Demo2024NIS2!

# Access code your clients type to unlock the demo (case-insensitive).
# This is the code you hand out with the link.
VITE_ACCESS_CODE=SAO2026
