# Public base URL of the telematics backend API (the client appends /api/v1).
# Leave unset in local dev to use the Vite proxy (relative /api/v1 → :4000).
VITE_API_URL=

# Map provider used by the <FleetMap /> abstraction: leaflet | mapbox | google
# Defaults to "leaflet" (no token required). Mapbox/Google fall back to Leaflet
# automatically when their access token/key below is missing.
VITE_MAP_PROVIDER=leaflet

# Required only when VITE_MAP_PROVIDER=mapbox
VITE_MAPBOX_TOKEN=

# Required only when VITE_MAP_PROVIDER=google
VITE_GOOGLE_MAPS_KEY=
