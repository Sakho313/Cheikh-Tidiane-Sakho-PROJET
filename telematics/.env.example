# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://telematics:telematics@localhost:5432/telematics_db

# ─── JWT (≥ 16 caractères chacun) ─────────────────────────────────────────────
JWT_SECRET=change-me-super-secret-jwt-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key
JWT_REFRESH_EXPIRES_IN=30d

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5174

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ─── Ingestion télématique ────────────────────────────────────────────────────
# Clé partagée que les boîtiers GPS envoient dans l'en-tête `x-api-key`
# pour pousser des positions sans token utilisateur (POST /telemetry/ingest).
INGEST_API_KEY=change-me-device-ingest-key
# Limite de vitesse par défaut (km/h) si le véhicule n'en définit pas.
DEFAULT_SPEED_LIMIT_KMH=90
